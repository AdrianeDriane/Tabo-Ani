ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=taboani;Username=postgres;Password=postgres
Frontend__ClientAppBaseUrl=http://localhost:5173
Frontend__AllowedOrigins__0=http://localhost:5173
Auth__Issuer=TaboAni.Api
Auth__Audience=TaboAni.Client
Auth__SigningKey=replace-with-a-random-secret-at-least-32-characters-long
Auth__AccessTokenLifetimeMinutes=15
Auth__RefreshTokenLifetimeDays=7
Auth__RefreshTokenCookieName=taboani_refresh_token
Auth__RefreshTokenCookiePath=/api/v1/auth
Auth__RefreshTokenCookieSameSite=None
Auth__UseSecureRefreshTokenCookie=true
EmailVerification__VerificationPath=/verify-email
EmailVerification__TokenLifetimeHours=24
EmailVerification__ResendCooldownSeconds=60
SignupPolicies__TermsVersion=2026-04-05
SignupPolicies__PrivacyVersion=2026-04-05
