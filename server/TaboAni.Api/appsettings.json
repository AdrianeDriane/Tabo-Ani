{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Frontend": {
    "ClientAppBaseUrl": "http://localhost:5173",
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Auth": {
    "Issuer": "TaboAni.Api",
    "Audience": "TaboAni.Client",
    "SigningKey": "",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 7,
    "RefreshTokenCookieName": "taboani_refresh_token",
    "RefreshTokenCookiePath": "/api/v1/auth",
    "RefreshTokenCookieSameSite": "None",
    "UseSecureRefreshTokenCookie": true
  },
  "EmailVerification": {
    "VerificationPath": "/verify-email",
    "TokenLifetimeHours": 24,
    "ResendCooldownSeconds": 60
  },
  "SignupPolicies": {
    "TermsVersion": "2026-04-05",
    "PrivacyVersion": "2026-04-05"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromName": "Tabo-Ani",
    "FromEmail": "",
    "UseStartTls": true
  },
  "RateLimiting": {
    "Auth": {
      "LoginPermitLimit": 5,
      "LoginWindowMinutes": 15,
      "RefreshPermitLimit": 30,
      "RefreshWindowMinutes": 5,
      "SignupPermitLimit": 5,
      "SignupWindowMinutes": 15,
      "ResendPermitLimit": 3,
      "ResendWindowMinutes": 15,
      "VerifyPermitLimit": 10,
      "VerifyWindowMinutes": 15,
      "QueueLimit": 0
    }
  },
  "AllowedHosts": "*"
}
